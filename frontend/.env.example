# BrightClause Frontend Configuration (server-side only, never exposed to client)

# Backend API URL
BACKEND_URL=http://localhost:8002

# Backend API key (must match API_KEY in backend .env)
BACKEND_API_KEY=

# Proxy secret - clients must send this as x-proxy-token header (optional for local dev)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
PROXY_SECRET=
